Table contato_empresarial [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	email varchar(100) [ not null ]
	telefone varchar(12)
	site text
}

Table endereco [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	estado varchar(2) [ not null ]
	cidade text [ not null ]
	bairro text
	cep varchar(8) [ not null ]
	logradouro text [ not null ]
	numero varchar(10)
}

Table empresa [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_endereco uuid [ not null ]
	fk_contato_empresarial uuid [ not null ]
	cnpj varchar(14) [ not null ]
	nome_fantasia varchar(120) [ not null ]
	razao_social varchar(120) [ not null ]

	Note: 'Supertipo organizacional'
}

Table fornecedor [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_empresa uuid [ not null ]
	tipo_empresa varchar(40)
	status boolean [ not null ]
}

Table demandante [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	tipo_empresa varchar(40)
	fk_empresa uuid [ not null ]
}

Table cargo [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	nome varchar(12) [ not null ]
	mascara text [ not null ]

	Note: 'Permissionamento governado pelo backend'
}

Table cargos_empresa [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_empresa uuid [ not null ]
	fk_cargo uuid [ not null ]
}

Table usuarios_empresa [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	id_usuario uuid [ pk, not null ]
	fk_empresa uuid [ not null ]
	fk_cargo uuid [ not null ]

	Note: 'Vinculo de acesso organizacional'
}

Table planos_empresa [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	nome text [ not null ]
	valor numeric [ not null ]
	ciclo varchar(20) [ not null ]
}

Table assinatura [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_fornecedor uuid [ not null ]
	fk_plano uuid [ not null ]
	status boolean [ not null ]
	renovacao_automatica boolean [ not null, default: true ]
	data_inicio timestamp [ not null ]
	data_fim timestamp
}

Table cobrancas [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_assinatura uuid [ not null ]
	valor numeric [ not null ]
	metodo_pagamento varchar(30) [ not null ]
	status boolean [ not null ]
	data_pagamento timestamptz [ not null ]

	Note: 'Pagamento dos planos'
}

Table modelo [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	marca text [ not null ]
	modelo text [ not null ]
	potencia_wp numeric [ not null ]
	eficiencia numeric [ not null ]
	dimensao numeric [ not null ]
	peso numeric [ not null ]
	status numeric [ not null, default: em_analise ]

	Note: 'Modelo de placa solar'
}

Table estoque [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_fornecedor uuid [ not null ]
	fk_modelo uuid [ not null ]
	quantidade integer [ not null ]

	Note: 'Estoque real do fornecedor'
}

Table ofertas [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_fornecedor uuid [ not null ]
	fk_modelo uuid [ not null ]
	preco_unidade numeric [ not null ]
	disponibilidade integer [ not null ]
	data_vencimento timestamp

	Note: 'Oferta publicada pelo fornecedor'
}

Table unidade_local [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_demandante uuid [ not null ]
	fk_endereco uuid [ not null ]
	complemento text
	tipo_local varchar(30) [ not null ]
}

Table especificacoes_unidade [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_unidade_local uuid [ not null ]
	fotos_local path
	data timestamptz [ not null, default: `now()` ]
}

Table profissional [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	id_usuario uuid [ not null ]

	Note: 'Profissional tecnico'
}

Table profissional_vinculo [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_empresa uuid [ not null ]
	fk_tecnico uuid [ not null ]
	tipo_vinculo varchar(40) [ not null ]

	Note: 'Escopo organizacional do tecnico'
}

Table especialidade [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	nome varchar(100) [ not null ]
	exige_registro boolean [ not null ]
}

Table servico_tecnico [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_projeto uuid [ not null ]
	finalidade text [ not null ]
	status boolean [ not null ]
	data_inicio timestamp [ not null ]
	data_fim timestamp [ not null ]
}

Table servico_executores [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_servico uuid [ not null ]
	fk_tecnico_vinculo uuid [ not null ]
	funcao text [ not null ]
}

Table projeto_tecnico [headercolor: #175e7a] {
	id uuid [ pk, not null ]
	fk_demandante uuid [ not null ]
	fk_unidade uuid [ not null ]
	status boolean [ not null ]
	data_inicio timestamp [ not null ]
	data_fim timestamp [ not null ]
}

Table registro_profissional [headercolor: #175e7a] {
	id uuid [ pk, not null ]
	fk_profissional uuid [ not null ]
	fk_especialidade uuid [ not null ]
	conselho varchar(60) [ not null ]
	numero varchar(30) [ not null ]
	data_validade timestamp [ not null ]
}

Table geolocalizacao [headercolor: #175e7a] {
	id uuid [ pk, not null ]
	fk_endereco uuid [ not null ]
	latitude varchar(20) [ not null ]
	longitude varchar(20) [ not null ]
}

Table certificacao [headercolor: #175e7a] {
	id uuid [ pk, not null ]
	fk_profissional uuid [ not null ]
	tipo_certificao varchar(30) [ not null ]
	informacoes text [ not null ]
	imagem text
}

Table usuario [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	id_autenticacao uuid [ not null ]

	Note: 'Profissional tecnico'
}

Ref "" {
	especificacoes_unidade.fk_unidade_local > unidade_local.id [ delete: no action, update: no action ]
}

Ref "" {
	unidade_local.fk_endereco > endereco.id [ delete: no action, update: no action ]
}

Ref "" {
	unidade_local.fk_demandante > demandante.id [ delete: no action, update: no action ]
}

Ref "" {
	empresa.fk_endereco > endereco.id [ delete: no action, update: no action ]
}

Ref "" {
	empresa.fk_contato_empresarial > contato_empresarial.id [ delete: no action, update: no action ]
}

Ref "" {
	fornecedor.fk_empresa > empresa.id [ delete: no action, update: no action ]
}

Ref "" {
	demandante.fk_empresa > empresa.id [ delete: no action, update: no action ]
}

Ref "" {
	usuarios_empresa.fk_empresa > empresa.id [ delete: no action, update: no action ]
}

Ref "" {
	usuarios_empresa.fk_cargo > cargo.id [ delete: no action, update: no action ]
}

Ref "" {
	cargos_empresa.fk_empresa > empresa.id [ delete: no action, update: no action ]
}

Ref "" {
	cargos_empresa.fk_cargo > cargo.id [ delete: no action, update: no action ]
}

Ref "" {
	assinatura.fk_fornecedor > fornecedor.id [ delete: no action, update: no action ]
}

Ref "" {
	assinatura.fk_plano > planos_empresa.id [ delete: no action, update: no action ]
}

Ref "" {
	cobrancas.fk_assinatura > assinatura.id [ delete: no action, update: no action ]
}

Ref "" {
	estoque.fk_fornecedor > fornecedor.id [ delete: no action, update: no action ]
}

Ref "" {
	estoque.fk_modelo > modelo.id [ delete: no action, update: no action ]
}

Ref "" {
	ofertas.fk_fornecedor > fornecedor.id [ delete: no action, update: no action ]
}

Ref "" {
	ofertas.fk_modelo > modelo.id [ delete: no action, update: no action ]
}

Ref "" {
	profissional_vinculo.fk_empresa > empresa.id [ delete: no action, update: no action ]
}

Ref "" {
	profissional_vinculo.fk_tecnico > profissional.id [ delete: no action, update: no action ]
}

Ref "" {
	servico_executores.fk_servico > servico_tecnico.id [ delete: no action, update: no action ]
}

Ref "" {
	servico_executores.fk_tecnico_vinculo > profissional_vinculo.id [ delete: no action, update: no action ]
}

Ref "" {
	projeto_tecnico.fk_demandante > demandante.id [ delete: no action, update: no action ]
}

Ref "" {
	projeto_tecnico.id < servico_tecnico.fk_projeto [ delete: no action, update: no action ]
}

Ref "" {
	especialidade.id < registro_profissional.fk_especialidade [ delete: no action, update: no action ]
}

Ref "" {
	registro_profissional.fk_profissional > profissional.id [ delete: no action, update: no action ]
}

Ref "" {
	projeto_tecnico.fk_unidade > unidade_local.id [ delete: no action, update: no action ]
}

Ref "" {
	geolocalizacao.fk_endereco - endereco.id [ delete: no action, update: no action ]
}

Ref "" {
	certificacao.fk_profissional > profissional.id [ delete: no action, update: no action ]
}

Ref "" {
	profissional.id_usuario > usuario.id [ delete: no action, update: no action ]
}

Ref "" {
	usuarios_empresa.id_usuario - usuario.id [ delete: no action, update: no action ]
}