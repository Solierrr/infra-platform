enum status_modelo {
	aprovada
	recusada
	em_analise
}



enum status_fornecedor {
	ativo
	suspenso
	desativado
}



enum status_proposta {
	aberta
	em_negociacao
	aceita
	recusada
	cancelada
}



enum status_assinatura {
	pago
	em_debito
	suspenso
}



enum status_servico {
	aberto
	em_andamento
	concluido
	cancelado
}



enum ciclo_plano {
	mensal
	semanal
	anual
}



enum tipo_local {
	predio
	casa
	complexo
}



enum tipo_vinculo_tecnico {
	independente
	afiliado
	parceiro
}



enum metodo_pagamento {
	pix
	boleto
	cartao_credito
	transferencia
}



enum status_cobranca {
	pendente
	pago
	cancelado
	estornado
}

Table usuario [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	avatar text
}

Table contato [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	email_trabalho varchar(100)
	email_pessoal varchar(100)
	telefone_trabalho varchar(12)
	telefone_pessoal varchar(12)
}

Table contato_empresarial [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	email_empresa varchar(100) [ not null ]
	telefone varchar(12)
	site path
}

Table pessoa [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_usuario uuid
	fk_contato uuid
	nome varchar(60) [ not null ]
	cpf varchar(11) [ not null ]
	data_nascimento date [ not null ]
}

Table endereco [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	estado varchar(2) [ not null ]
	cidade text [ not null ]
	bairro text
	cep varchar(8) [ not null ]
	logradouro text [ not null ]
	numero varchar(10)
}

Table empresa [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_endereco uuid [ not null ]
	fk_contato_empresarial uuid [ not null ]
	cnpj varchar(14) [ not null ]
	nome_fantasia varchar(120) [ not null ]

	Note: 'Supertipo organizacional'
}

Table fornecedor [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_empresa uuid [ not null ]
	status status_fornecedor [ not null, default: ativo ]
}

Table demandante [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_empresa uuid [ not null ]
}

Table empresa_tecnica [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_empresa uuid [ not null ]

	Note: 'Empresa especializada em servicos tecnicos'
}

Table cargo [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	nome varchar(12) [ not null ]
	acessos text [ not null, note: 'Código definido pelo backend' ]

	Note: 'Permissionamento governado pelo backend'
}

Table cargos_empresa [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_empresa uuid [ not null ]
	fk_cargo uuid [ not null ]
}

Table usuarios_empresa [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_empresa uuid [ not null ]
	fk_usuario uuid [ not null ]
	fk_cargo uuid [ not null ]

	Note: 'Vinculo de acesso organizacional'
}

Table planos_empresa [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	nome text [ not null ]
	valor money [ not null ]
	ciclo ciclo_plano [ not null ]
}

Table assinatura [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_fornecedor uuid [ not null ]
	fk_plano uuid [ not null ]
	status status_assinatura [ not null, default: pago ]
	renovacao_automatica boolean [ not null, default: true ]
	data_inicio timestamptz [ not null ]
	data_fim timestamptz
}

Table cobrancas [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_assinatura uuid [ not null ]
	valor money [ not null ]
	metodo_pagamento metodo_pagamento [ not null ]
	status status_cobranca [ not null, default: pendente ]
	data_pagamento timestamptz

	Note: 'Pagamento dos planos'
}

Table modelo [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	marca text [ not null ]
	modelo text [ not null ]
	potencia_wp numeric [ not null ]
	eficiencia numeric [ not null, note: 'Ex: 0.2150 = 21.50%' ]
	dimensao numeric [ not null, note: 'Em metros quadrados' ]
	peso numeric [ not null, note: 'Em kg' ]
	status numeric [ not null, default: em_analise ]

	Note: 'Modelo de placa solar'
}

Table estoque [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_fornecedor uuid [ not null ]
	fk_modelo uuid [ not null ]
	quantidade integer [ not null ]

	Note: 'Estoque real do fornecedor'
}

Table ofertas [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_fornecedor uuid [ not null ]
	fk_modelo uuid [ not null ]
	preco_unidade money [ not null ]
	disponibilidade integer [ not null ]
	data_vencimento timestamptz

	Note: 'Oferta publicada pelo fornecedor'
}

Table unidade_local [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_demandante uuid [ not null ]
	fk_endereco uuid [ not null ]
	complemento text
	tipo_local tipo_local [ not null ]
}

Table especificacoes_unidade [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_unidade_local uuid [ not null ]
	especificacoes text
	fotos_local text
	data timestamptz [ not null, default: `now()` ]

	Note: 'Historico das especificacoes do local'
}

Table conta_energia [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_unidade_local uuid [ not null ]
	consumo numeric [ not null, note: 'Em kWh' ]
	preco money [ not null ]
}

Table proposta [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_demandante uuid [ not null ]
	status status_proposta [ not null, default: aberta ]
	observacoes text
	valor_total money
	data_criacao timestamptz [ not null, default: `now()` ]
	data_atualizacao timestamptz

	Note: 'Cabecalho da negociacao comercial'
}

Table proposta_item [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_proposta uuid [ not null ]
	fk_oferta uuid [ not null ]
	quantidade integer [ not null ]
	preco_negociado money
	desconto numeric [ note: 'Ex: 0.05 = 5%' ]

	Note: '1 proposta pode referenciar N ofertas (modelos distintos)'
}

Table proposta_unidade [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_proposta_item uuid [ not null ]
	fk_unidade_local uuid [ not null ]
	quantidade integer [ not null ]
	observacao text

	Note: 'Distribuicao de entrega por unidade local'
}

Table tecnico [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_pessoa uuid [ not null ]
	crea text [ not null ]

	Note: 'Profissional tecnico'
}

Table tecnico_vinculo [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_empresa uuid [ not null ]
	fk_tecnico uuid [ not null ]
	tipo_vinculo tipo_vinculo_tecnico [ not null ]

	Note: 'Escopo organizacional do tecnico'
}

Table especializacao [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	tipo text [ not null ]
}

Table tecnico_especializacao [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_tecnico uuid [ not null ]
	fk_especializacao uuid [ not null ]
}

Table servico_tecnico [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_demandante uuid [ not null ]
	finalidade text [ not null ]
	status status_servico [ not null, default: aberto ]
	data_criacao timestamptz [ not null, default: `now()` ]
}

Table servico_executores [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_servico uuid [ not null ]
	fk_tecnico_vinculo uuid [ not null ]
	funcao text [ not null ]

	Note: 'Execucao do servico via vinculo tecnico'
}

Table contrato_servico [headercolor: #175e7a] {
	id uuid [ pk, not null, unique ]
	fk_servico uuid [ not null ]
	garantia text
	prazo_entrega date
	seguro boolean [ not null, default: false ]
	homologacao_distribuidora boolean [ not null, default: false ]

	Note: 'Condicoes contratuais do servico'
}

Ref "" {
	conta_energia.fk_unidade_local > unidade_local.id [ delete: no action, update: no action ]
}

Ref "" {
	especificacoes_unidade.fk_unidade_local > unidade_local.id [ delete: no action, update: no action ]
}

Ref "" {
	unidade_local.fk_endereco > endereco.id [ delete: no action, update: no action ]
}

Ref "" {
	unidade_local.fk_demandante > demandante.id [ delete: no action, update: no action ]
}

Ref "" {
	empresa.fk_endereco > endereco.id [ delete: no action, update: no action ]
}

Ref "" {
	empresa.fk_contato_empresarial > contato_empresarial.id [ delete: no action, update: no action ]
}

Ref "" {
	fornecedor.fk_empresa > empresa.id [ delete: no action, update: no action ]
}

Ref "" {
	demandante.fk_empresa > empresa.id [ delete: no action, update: no action ]
}

Ref "" {
	empresa_tecnica.fk_empresa > empresa.id [ delete: no action, update: no action ]
}

Ref "" {
	pessoa.fk_usuario > usuario.id [ delete: no action, update: no action ]
}

Ref "" {
	pessoa.fk_contato > contato.id [ delete: no action, update: no action ]
}

Ref "" {
	usuarios_empresa.fk_empresa > empresa.id [ delete: no action, update: no action ]
}

Ref "" {
	usuarios_empresa.fk_usuario > usuario.id [ delete: no action, update: no action ]
}

Ref "" {
	usuarios_empresa.fk_cargo > cargo.id [ delete: no action, update: no action ]
}

Ref "" {
	cargos_empresa.fk_empresa > empresa.id [ delete: no action, update: no action ]
}

Ref "" {
	cargos_empresa.fk_cargo > cargo.id [ delete: no action, update: no action ]
}

Ref "" {
	assinatura.fk_fornecedor > fornecedor.id [ delete: no action, update: no action ]
}

Ref "" {
	assinatura.fk_plano > planos_empresa.id [ delete: no action, update: no action ]
}

Ref "" {
	cobrancas.fk_assinatura > assinatura.id [ delete: no action, update: no action ]
}

Ref "" {
	estoque.fk_fornecedor > fornecedor.id [ delete: no action, update: no action ]
}

Ref "" {
	estoque.fk_modelo > modelo.id [ delete: no action, update: no action ]
}

Ref "" {
	ofertas.fk_fornecedor > fornecedor.id [ delete: no action, update: no action ]
}

Ref "" {
	ofertas.fk_modelo > modelo.id [ delete: no action, update: no action ]
}

Ref "" {
	proposta.fk_demandante > demandante.id [ delete: no action, update: no action ]
}

Ref "" {
	proposta_item.fk_proposta > proposta.id [ delete: no action, update: no action ]
}

Ref "" {
	proposta_item.fk_oferta > ofertas.id [ delete: no action, update: no action ]
}

Ref "" {
	proposta_unidade.fk_proposta_item > proposta_item.id [ delete: no action, update: no action ]
}

Ref "" {
	proposta_unidade.fk_unidade_local > unidade_local.id [ delete: no action, update: no action ]
}

Ref "" {
	tecnico.fk_pessoa > pessoa.id [ delete: no action, update: no action ]
}

Ref "" {
	tecnico_vinculo.fk_empresa > empresa.id [ delete: no action, update: no action ]
}

Ref "" {
	tecnico_vinculo.fk_tecnico > tecnico.id [ delete: no action, update: no action ]
}

Ref "" {
	tecnico_especializacao.fk_tecnico > tecnico.id [ delete: no action, update: no action ]
}

Ref "" {
	tecnico_especializacao.fk_especializacao > especializacao.id [ delete: no action, update: no action ]
}

Ref "" {
	servico_tecnico.fk_demandante > demandante.id [ delete: no action, update: no action ]
}

Ref "" {
	servico_executores.fk_servico > servico_tecnico.id [ delete: no action, update: no action ]
}

Ref "" {
	servico_executores.fk_tecnico_vinculo > tecnico_vinculo.id [ delete: no action, update: no action ]
}

Ref "" {
	contrato_servico.fk_servico > servico_tecnico.id [ delete: no action, update: no action ]
}